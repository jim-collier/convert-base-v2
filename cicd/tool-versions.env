## Pinned versions for the go-installed pipeline tools, so results don't drift
## across machines or over time. One place for both the local pipeline
## (utility/pin-tools.bash brings installs in line) and the workflows under
## .github/workflows (which grep what they need out of this file).
## staticcheck v0.7.0 is the 2026.1 release.
GOLANGCI_LINT_VERSION=v2.12.2
STATICCHECK_VERSION=v0.7.0
GOVULNCHECK_VERSION=v1.5.0
GORELEASER_VERSION=v2.17.0
